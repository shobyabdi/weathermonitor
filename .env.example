# AI — required
ANTHROPIC_API_KEY=sk-ant-xxx

# Cache — required for cross-user AI dedup and baseline persistence
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# Weather data
OPENWEATHERMAP_API_KEY=xxx
YOUTUBE_DATA_API_KEY=xxx
NASA_FIRMS_API_KEY=xxx
OPENAQ_API_KEY=xxx
TOMORROW_IO_API_KEY=xxx

# Backend
DATABASE_URL=sqlite:///./weather.db
POLL_INTERVAL_SECONDS=600
STORM_SCORE_THRESHOLD=60
ALERT_THRESHOLD=70

# Frontend (Vite)
VITE_MAPLIBRE_STYLE=https://basemaps.cartocdn.com/gl/dark-matter-gl-style/style.json
VITE_API_BASE_URL=http://localhost:8000
